{
	"name": "prechop",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=20.11.0"
	},
	"scripts": {
		"ts.check": "tsc --project tsconfig.json",
		"ts.check.test": "tsc --project tsconfig.vitest.json",
		"dev": "next dev",
		"build": "next build",
		"postbuild": "next-sitemap",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"fix-unsafe": "biome check --write --unsafe",
		"seed": "node --conditions react-server --import tsx --env-file=.env scripts/seed.ts",
		"migrate:iam": "node --conditions react-server --import tsx --env-file=.env scripts/migrate-iam.ts",
		"migrate:menu-categories": "node --conditions react-server --import tsx --env-file=.env scripts/migrate-menu-categories.ts",
		"e2e": "playwright test",
		"test": "vitest run",
		"test.coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1045.0",
		"@aws-sdk/s3-request-presigner": "^3.1045.0",
		"@react-pdf/renderer": "^4.5.1",
		"axios": "^1.16.0",
		"bcrypt": "^6.0.0",
		"cron": "^4.4.0",
		"hash.js": "^1.1.7",
		"ioredis": "^5.10.1",
		"jose": "^6.2.3",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.6.2",
		"motion": "^12.38.0",
		"next": "16.2.10",
		"next-sitemap": "^4.2.3",
		"nextjs-toploader": "^3.9.17",
		"prom-client": "^15.1.2",
		"qrcode": "^1.5.4",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-icons": "^5.6.0",
		"react-phone-number-input": "^3.4.16",
		"react-select": "^5.10.2",
		"react-spinners": "^0.17.0",
		"resend": "^4.5.1",
		"server-only": "^0.0.1",
		"sharp": "^0.34.5",
		"styled-components": "^6.4.1",
		"swr": "^2.4.1",
		"uuid": "11.1.1",
		"validator": "^13.15.35",
		"web-push": "^3.6.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@playwright/test": "^1.60.0",
		"@types/bcrypt": "^6.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19",
		"@types/uuid": "^10.0.0",
		"@types/validator": "^13.15.10",
		"@types/web-push": "^3.6.4",
		"@vitest/coverage-v8": "^4.1.10",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"resolutions": {
		"postcss": "^8.5.10"
	}
}
