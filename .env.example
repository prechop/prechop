# ─────────────────────────────────────────────────────────────────────────
# Prechop — environment template.
# Copy to `.env` for local dev (fill real values) and to `.env.production`
# for deploys. NEVER commit a filled-in copy: `.env` and `.env.production`
# are gitignored on purpose.
# ─────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=3000
# Server origin for Paystack callback URLs, receipt links and external payment
# links. TWO vars, on purpose:
#   * APP_URL is the RUNTIME server origin. The server reads this FIRST
#     (src/server/constants/environments.ts). Set it per-deploy so the origin can
#     change without a rebuild. In a container it is injected at run time (the
#     platform secret store / compose `environment:`), NOT baked into the image.
#   * NEXT_PUBLIC_APP_URL is BUILD-TIME only — `next build` inlines it into the
#     client bundle, so it is frozen at build and cannot be corrected by a
#     deploy-time env. It is the browser fallback when APP_URL is unset. In
#     Docker it is passed as a build ARG (see Dockerfile / compose.yaml).
# Boot REFUSES to start in production if the resolved origin is unset or points
# at localhost/127.0.0.1 — real buyers would be redirected to a dead host after
# paying. Set both to the public origin (e.g. https://prechop.ng) in production.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database & cache
# Local dev uses the SHARED Docker containers on this machine — Mongo is
# published on 27018 (NOT the 27017 default) and Redis on 6379. Do not start a
# second Mongo/Redis for this project; see compose.yaml.
#   Required in production: an empty REDIS_URI makes ioredis silently fall back
#   to 127.0.0.1:6379, and boot now refuses that.
MONGODB_URI=mongodb://127.0.0.1:27018
DB_NAME=prechop
REDIS_URI=redis://127.0.0.1:6379
# If you connect to that shared Mongo from INSIDE a container, append
# `/?directConnection=true` — it is a replica set (rs0) whose member advertises
# itself as `localhost:27018`, which a container would resolve to itself:
#   MONGODB_URI=mongodb://host.docker.internal:27018/?directConnection=true

# Auth — HS256 dual secret (the two MUST differ). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_TOKEN_SECRET=replace-with-48-byte-hex-secret
JWT_REFRESH_TOKEN_SECRET=replace-with-a-different-48-byte-hex-secret
ACCESS_TOKEN_MAX_AGE=15m
REFRESH_TOKEN_MAX_AGE=30d
COOKIE_DOMAIN=

# PII encryption — 32-byte hex (64 chars) for AES-256-GCM. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-char-hex-key

# Storage (S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Payments (Paystack — use test keys for dev, live keys in prod)
# REQUIRED in production: webhook signatures are HMAC-verified with this key, so
# an empty value verifies against a publicly-known key and lets anyone forge a
# "payment succeeded" webhook. Boot refuses to start without it.
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Comms — SMS/OTP. Valid values: console | sendchamp
# `console` logs the OTP to stdout while the API still reports "sent" — fine for
# local dev, and REJECTED at boot in production (nobody could ever log in).
# Production must use `sendchamp`, which then also REQUIRES SENDCHAMP_API_KEY.
OTP_PROVIDER=console
# ⚠ If your key contains a `$`, escape it as `$$` in any file Docker Compose
# interpolates, or Compose will silently swallow it and truncate the key.
SENDCHAMP_API_KEY=
SENDCHAMP_SENDER_ID=PreChop

# Comms — email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@prechop.ng

# Web-push (VAPID). Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@prechop.ng
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Platform fees
PLATFORM_FEE_VENDOR_PERCENT=8
PLATFORM_FEE_BUYER_PERCENT=3
PLATFORM_FEE_BUYER_MAX_KOBO=20000

# Observability & ops
# METRICS_ENABLED is ignored in production — /api/metrics always requires
# METRICS_TOKEN there.
METRICS_ENABLED=1
METRICS_TOKEN=replace-with-a-metrics-token
# Set TRUSTED_PROXY=1 ONLY behind a trusted edge/load balancer. When 0, the
# forwarded-IP headers are client-supplied, so rate limits and IP binding can be
# spoofed. Boot warns about this in production.
TRUSTED_PROXY=0
# Local/e2e escape hatch. NEVER set this to 1 in production — it disables rate
# limiting entirely.
DISABLE_RATE_LIMIT=0

# Seed
SEED_ADMIN_PHONE=08130135756

# Tests — the port Playwright boots its `next start` webServer on (see
# playwright.config.ts). Only needed if 3100 is already taken.
E2E_PORT=3100
