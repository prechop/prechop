# pnpm configuration
# Hoist the native/server externals Next expects to resolve from node_modules
# at runtime (they are listed in next.config serverExternalPackages).
public-hoist-pattern[]=*sharp*
public-hoist-pattern[]=*bcrypt*
public-hoist-pattern[]=*@aws-sdk*
public-hoist-pattern[]=*mongoose*
public-hoist-pattern[]=*styled-components*
strict-peer-dependencies=false
auto-install-peers=true
